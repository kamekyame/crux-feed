{
  "nodeModulesDir": "manual",
  "tasks": {
    "dev": "vite",
    "start": "deno serve -P --env _fresh/server.js",
    "start:tunnel": "deno serve -P --env --tunnel _fresh/server.js",
    "build": "vite build",
    "update": "deno run -A -r jsr:@fresh/update .",
    "test": "deno test -A",
    "test:update": "deno test -A -- --update"
  },
  "imports": {
    "#/": "./",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "@napi-rs/canvas": "npm:@napi-rs/canvas@^0.1.97",
    "@napi-rs/canvas-linux-x64-gnu": "npm:@napi-rs/canvas-linux-x64-gnu@^0.1.97",
    "@preact/signals": "npm:@preact/signals@^2.9.0",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/collections": "jsr:@std/collections@^1.1.6",
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "@std/xml": "jsr:@std/xml@^0.1.0",
    "chart.js": "npm:chart.js@^4.5.1",
    "chartjs-plugin-annotation": "npm:chartjs-plugin-annotation@^3.1.0",
    "colord": "npm:colord@^2.9.3",
    "crux-api": "npm:crux-api@^4.1.0",
    "feed": "npm:feed@^5.2.0",
    "fresh": "jsr:@fresh/core@^2.2.2",
    "preact": "npm:preact@^10.29.0",
    "vite": "npm:vite@^7.3.1"
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ],
      "include": [
        "no-console"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*"
  ],
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  },
  "permissions": {
    "default": {
      "net": {
        "allow": ["chromeuxreport.googleapis.com:443"]
      },
      "env": {
        "allow": ["GOOGLE_API_KEY"],
        "ignore": [
          "NAPI_RS_NATIVE_LIBRARY_PATH",
          "NAPI_RS_FORCE_WASI",
          "DISABLE_SYSTEM_FONTS_LOAD"
        ]
      },
      "read": {
        "allow": ["./_fresh/", "**@napi-rs**"]
      },
      "ffi": true,
      "sys": true
    }
  },
  "deploy": {
    "org": "kamekyame",
    "app": "crux-feed"
  }
}
